# =============================================================================
# CampusVerse AI — copy this file to `.env` and fill in your keys
# Location: C:\Users\10sat\Desktop\CampusVerse\backend\.env
# NEVER commit `.env` to git
# =============================================================================

# --- GROQ AI (required for live AI roadmaps, companion chat, planner) -----
# Get key: https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_groq_key_here

# --- DATABASE: choose ONE option -------------------------------------------

# OPTION A — Neon (recommended for hackathon / no local Docker)
# Neon dashboard → your project → Connect → copy connection string
# Paste the full string below (postgresql:// or postgres:// both work)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-xxxx.region.aws.neon.tech/neondb?sslmode=require

# OPTION B — Local Docker Postgres (docker compose up -d postgres)
# DATABASE_URL=postgresql+asyncpg://campusverse:campusverse@localhost:5432/campusverse

# SSL: auto-enabled for neon.tech URLs; override only if needed
# DATABASE_SSL=true

# --- Optional ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000
DEMO_MODE=true
